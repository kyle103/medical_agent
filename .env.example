# 文档版本：V1.0
# 生效日期：{{文档生成日期}}  # 待用户手动填充

# ========== 1) LLM 模型配置 ==========
LLM_API_BASE={{LLM_API地址}}  # 待用户手动填充
LLM_API_KEY={{LLM_API密钥}}  # 待用户手动填充
LLM_MODEL_NAME={{LLM模型名称}}  # 待用户手动填充
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ========== 2) Embedding 配置 ==========
EMBEDDING_TYPE={{local/api}}  # 待用户手动填充
EMBEDDING_MODEL_PATH={{本地Embedding模型路径}}  # 待用户手动填充（本地）
EMBEDDING_API_BASE={{Embedding API地址}}  # 待用户手动填充（API）
EMBEDDING_API_KEY={{Embedding API密钥}}  # 待用户手动填充（API）
EMBEDDING_MODEL_NAME={{Embedding模型名称}}  # 待用户手动填充

# ========== 3) 数据库配置 ==========
DB_TYPE={{sqlite/mysql}}  # 待用户手动填充
SQLITE_DB_PATH={{本地SQLite文件路径}}  # 待用户手动填充
MYSQL_HOST={{MySQL地址}}  # 待用户手动填充
MYSQL_PORT={{MySQL端口}}  # 待用户手动填充
MYSQL_USER={{MySQL用户名}}  # 待用户手动填充
MYSQL_PASSWORD={{MySQL密码}}  # 待用户手动填充
MYSQL_DATABASE={{MySQL数据库名}}  # 待用户手动填充

# ========== 4) 向量库配置 ==========
VECTOR_STORE_TYPE={{chroma_file/chroma_server/qdrant}}  # 待用户手动填充
CHROMA_PERSIST_DIRECTORY={{本地Chroma存储路径}}  # 待用户手动填充
CHROMA_SERVER_HOST={{Chroma服务地址}}  # 待用户手动填充
CHROMA_SERVER_PORT={{Chroma服务端口}}  # 待用户手动填充
QDRANT_HOST={{Qdrant地址}}  # 待用户手动填充
QDRANT_PORT={{Qdrant端口}}  # 待用户手动填充
QDRANT_API_KEY={{Qdrant API密钥}}  # 待用户手动填充

# ========== 5) Redis 配置（生产） ==========
REDIS_HOST={{Redis地址}}  # 待用户手动填充
REDIS_PORT={{Redis端口}}  # 待用户手动填充
REDIS_PASSWORD={{Redis密码}}  # 待用户手动填充
REDIS_DB=0

# ========== 6) 安全配置 ==========
SECRET_KEY={{JWT加密密钥}}  # 待用户手动填充
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOWED_HOSTS={{允许的跨域域名列表}}  # 待用户手动填充

# ========== 7) 合规配置 ==========
FORCE_DISCLAIMER=true
ENABLE_INPUT_CHECK=true
ENABLE_OUTPUT_CHECK=true

# ========== 8) 服务配置 ==========
APP_ENV=local
LOG_LEVEL=INFO

import uuid

import pytest
from fastapi.testclient import TestClient

from app.main import app


@pytest.mark.asyncio
async def test_short_term_memory_recall_mode():
    """同一 user_id + session_id 下，多轮对话后，“你还记得/总结”等追问应能利用会话历史进行回答。

    当前实现采用“上下文记忆注入”，不再保证旧 recall_mode 的固定话术。
    因此这里只验证：不会 500，且回答能提及上一轮信息（张三）。
    """

    client = TestClient(app)

    # register user
    r = client.post("/api/v1/user/register", json={"user_nickname": f"t_{uuid.uuid4().hex[:8]}"})
    assert r.status_code == 200
    data = r.json()["data"]

    token = data.get("access_token") or data.get("token") or data.get("jwt")
    assert token

    headers = {"Authorization": f"Bearer {token}"}
    session_id = f"s_{uuid.uuid4().hex}"

    r1 = client.post(
        "/api/v1/chat/completion",
        headers=headers,
        json={"session_id": session_id, "user_input": "我叫张三", "stream": False, "enable_archive_link": True},
    )
    assert r1.status_code == 200

    r2 = client.post(
        "/api/v1/chat/completion",
        headers=headers,
        json={
            "session_id": session_id,
            "user_input": "你还记得我刚才说了什么吗？",
            "stream": False,
            "enable_archive_link": True,
        },
    )
    assert r2.status_code == 200

    out = r2.json()["data"]["assistant_output"]
    assert isinstance(out, str) and out.strip()
    assert "张三" in out
